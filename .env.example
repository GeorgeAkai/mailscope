# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/email_visibility?schema=public"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Enable Gmail API. Add redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"

# Cron job auth — generate with: openssl rand -base64 32
CRON_SECRET="replace-with-random-secret"
